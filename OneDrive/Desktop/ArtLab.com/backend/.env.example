# Local PostgreSQL (Docker)
DATABASE_URL="postgresql://artlab:artlab123@localhost:5432/artlab_db?schema=public"

# Для Supabase вместо строки выше используйте:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

# JWT (сгенерируйте длинные случайные строки, минимум 32 символа)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
# Используется для будущих сценариев; opaque refresh хранится в БД по SHA-256.
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Секрет «панели» (второй фактор для POST /auth/admin/login)
ADMIN_PANEL_PASSWORD="change-me-long-random-secret"

# CORS: URL фронтенда (Vite dev / продакшен)
FRONTEND_URL="http://localhost:5173"

# Административный вход: email пользователя в таблице users с role=ADMIN
# Сначала создайте пользователя через /auth/register, затем в БД:
# UPDATE users SET role = 'ADMIN' WHERE email = 'admin@example.com';
ADMIN_PANEL_EMAIL="admin@example.com"
